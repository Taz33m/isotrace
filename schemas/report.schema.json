{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://isotrace.dev/schemas/report.schema.json",
  "title": "IsoTrace Analyzer Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["report", "input", "result"],
  "properties": {
    "report": {
      "$ref": "#/$defs/envelope"
    },
    "input": {
      "$ref": "#/$defs/input"
    },
    "result": {
      "$ref": "#/$defs/analysisResult"
    }
  },
  "$defs": {
    "envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "generatedAt", "tool", "command", "runtime", "git"],
      "properties": {
        "schema": {
          "const": "isotrace.report.v1"
        },
        "generatedAt": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "command": {
          "type": "object",
          "additionalProperties": false,
          "required": ["argv", "cwd"],
          "properties": {
            "argv": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cwd": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["node", "platform", "arch", "osRelease"],
          "properties": {
            "node": {
              "type": "string",
              "minLength": 1
            },
            "platform": {
              "type": "string",
              "minLength": 1
            },
            "arch": {
              "type": "string",
              "minLength": 1
            },
            "osRelease": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "git": {
          "type": "object",
          "additionalProperties": false,
          "required": ["commit", "dirty"],
          "properties": {
            "commit": {
              "type": ["string", "null"]
            },
            "dirty": {
              "type": ["boolean", "null"]
            }
          }
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "analysisResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "history",
        "mode",
        "ok",
        "verdict",
        "nodes",
        "edges",
        "cycles",
        "ignoredTransactions",
        "kindCounts",
        "validationNotes"
      ],
      "properties": {
        "history": {
          "$ref": "https://isotrace.dev/schemas/history.schema.json"
        },
        "mode": {
          "enum": ["serializable", "strict-serializable"]
        },
        "ok": {
          "type": "boolean"
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edge"
          }
        },
        "cycles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cycle"
          }
        },
        "ignoredTransactions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kindCounts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ww", "wr", "rw", "rt"],
          "properties": {
            "ww": {
              "type": "integer",
              "minimum": 0
            },
            "wr": {
              "type": "integer",
              "minimum": 0
            },
            "rw": {
              "type": "integer",
              "minimum": 0
            },
            "rt": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "validationNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "serializable",
        "strictSerializable",
        "anomaly",
        "implicatedTransactions",
        "evidence",
        "summary",
        "explanation",
        "inspectFirst",
        "limitations"
      ],
      "properties": {
        "serializable": {
          "$ref": "#/$defs/checkVerdict"
        },
        "strictSerializable": {
          "$ref": "#/$defs/checkVerdict"
        },
        "anomaly": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "title"],
          "properties": {
            "label": {
              "enum": ["write-skew", "strict-stale-read", "dependency-cycle", "valid-serial-history", "aborted-write-ignored"]
            },
            "title": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "implicatedTransactions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "$ref": "#/$defs/verdictEvidence"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "inspectFirst": {
          "type": "string",
          "minLength": 1
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "checkVerdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {
          "enum": ["pass", "fail", "not-evaluated"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verdictEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "edgeIds", "edgeKinds", "proofEdges", "pattern"],
      "properties": {
        "kind": {
          "enum": ["cycle", "edge-pattern", "validation-note", "none"]
        },
        "cycleId": {
          "type": "string"
        },
        "edgeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "edgeKinds": {
          "type": "array",
          "items": {
            "enum": ["ww", "wr", "rw", "rt"]
          }
        },
        "proofEdges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/proofEdgeFact"
          }
        },
        "pattern": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "proofEdgeFact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edgeId", "edgeKind", "sourceTransaction", "targetTransaction", "sourceFact", "targetFact", "summary"],
      "properties": {
        "edgeId": {
          "type": "string",
          "minLength": 1
        },
        "edgeKind": {
          "enum": ["ww", "wr", "rw", "rt"]
        },
        "sourceTransaction": {
          "type": "string",
          "minLength": 1
        },
        "targetTransaction": {
          "type": "string",
          "minLength": 1
        },
        "sourceFact": {
          "type": "string",
          "minLength": 1
        },
        "targetFact": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "opCount"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "process": {
          "type": "string"
        },
        "begin": {
          "type": "number"
        },
        "commit": {
          "type": "number"
        },
        "opCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "to", "kind", "reason"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": ["ww", "wr", "rw", "rt"]
        },
        "key": {
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/jsonValue"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "cycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "classification", "summary", "edges", "transactions"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "enum": ["serializability", "strict-serializability", "dependency-cycle"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edge"
          }
        },
        "transactions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}
