{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://isotrace.dev/schemas/benchmark.schema.json",
  "title": "IsoTrace Benchmark Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["report", "benchmark"],
  "properties": {
    "report": {
      "$ref": "#/$defs/envelope"
    },
    "benchmark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "settings", "rows"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "settings": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sizes", "iterations"],
          "properties": {
            "sizes": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["transactions", "keys"],
                "properties": {
                  "transactions": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "keys": {
                    "type": "integer",
                    "minimum": 1
                  }
                }
              }
            },
            "iterations": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["transactions", "keys", "edges", "cycles", "durationMs"],
            "properties": {
              "transactions": {
                "type": "integer",
                "minimum": 1
              },
              "keys": {
                "type": "integer",
                "minimum": 1
              },
              "edges": {
                "type": "integer",
                "minimum": 0
              },
              "cycles": {
                "type": "integer",
                "minimum": 0
              },
              "durationMs": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "generatedAt", "tool", "command", "runtime", "git"],
      "properties": {
        "schema": {
          "const": "isotrace.report.v1"
        },
        "generatedAt": {
          "type": "string",
          "minLength": 1
        },
        "tool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "command": {
          "type": "object",
          "additionalProperties": false,
          "required": ["argv", "cwd"],
          "properties": {
            "argv": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cwd": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["node", "platform", "arch", "osRelease"],
          "properties": {
            "node": {
              "type": "string",
              "minLength": 1
            },
            "platform": {
              "type": "string",
              "minLength": 1
            },
            "arch": {
              "type": "string",
              "minLength": 1
            },
            "osRelease": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "git": {
          "type": "object",
          "additionalProperties": false,
          "required": ["commit", "dirty"],
          "properties": {
            "commit": {
              "type": ["string", "null"]
            },
            "dirty": {
              "type": ["boolean", "null"]
            }
          }
        }
      }
    }
  }
}
