{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://isotrace.dev/schemas/history.schema.json",
  "title": "IsoTrace History",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description", "transactions"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": ["serializable", "strict-serializable"]
    },
    "transactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/transaction"
      }
    }
  },
  "$defs": {
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ops"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "process": {
          "type": "string"
        },
        "begin": {
          "type": "number"
        },
        "commit": {
          "type": "number"
        },
        "status": {
          "enum": ["committed", "aborted"]
        },
        "ops": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/op"
          }
        }
      }
    },
    "op": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["read", "write", "predicate-read"]
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "$ref": "#/$defs/jsonValue"
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "table": {
          "type": "string",
          "minLength": 1
        },
        "rowId": {
          "$ref": "#/$defs/jsonValue"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        "predicate": {
          "type": "object"
        },
        "returnedRows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/predicateReadRow"
          }
        },
        "sourceSql": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "read"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["key", "value", "from"],
            "properties": {
              "predicate": {
                "$ref": "#/$defs/readPredicateEvidence"
              }
            },
            "not": {
              "anyOf": [
                {
                  "required": ["table"]
                },
                {
                  "required": ["rowId"]
                },
                {
                  "required": ["fields"]
                },
                {
                  "required": ["returnedRows"]
                },
                {
                  "required": ["sourceSql"]
                },
                {
                  "required": ["note"]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "write"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["key", "value"],
            "dependentRequired": {
              "table": ["rowId", "fields"],
              "rowId": ["table", "fields"],
              "fields": ["table", "rowId"]
            },
            "not": {
              "anyOf": [
                {
                  "required": ["from"]
                },
                {
                  "required": ["predicate"]
                },
                {
                  "required": ["returnedRows"]
                },
                {
                  "required": ["sourceSql"]
                },
                {
                  "required": ["note"]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "predicate-read"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["table", "predicate", "returnedRows"],
            "properties": {
              "predicate": {
                "$ref": "#/$defs/predicateExpression"
              }
            },
            "not": {
              "anyOf": [
                {
                  "required": ["from"]
                },
                {
                  "required": ["key"]
                },
                {
                  "required": ["value"]
                },
                {
                  "required": ["rowId"]
                },
                {
                  "required": ["fields"]
                }
              ]
            }
          }
        }
      ]
    },
    "predicateExpression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["column", "op", "value"],
      "properties": {
        "column": {
          "type": "string",
          "minLength": 1
        },
        "op": {
          "enum": ["=", "!=", "<", "<=", ">", ">="]
        },
        "value": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "predicateReadRow": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      },
      "properties": {
        "id": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "readPredicateEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["table", "where", "rowId", "sourceSql"],
      "properties": {
        "table": {
          "type": "string",
          "minLength": 1
        },
        "where": {
          "type": "string",
          "minLength": 1
        },
        "rowId": {
          "$ref": "#/$defs/jsonValue"
        },
        "sourceSql": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}
