{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://isotrace.dev/schemas/history.schema.json",
  "title": "IsoTrace History",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description", "transactions"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": ["serializable", "strict-serializable"]
    },
    "transactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/transaction"
      }
    }
  },
  "$defs": {
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ops"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "process": {
          "type": "string"
        },
        "begin": {
          "type": "number"
        },
        "commit": {
          "type": "number"
        },
        "status": {
          "enum": ["committed", "aborted"]
        },
        "ops": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/op"
          }
        }
      }
    },
    "op": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "key", "value"],
      "properties": {
        "type": {
          "enum": ["read", "write"]
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "$ref": "#/$defs/jsonValue"
        },
        "from": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "read"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["from"]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "write"
              }
            },
            "required": ["type"]
          },
          "then": {
            "not": {
              "required": ["from"]
            }
          }
        }
      ]
    },
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}
