{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://isotrace.dev/schemas/history.schema.json",
  "title": "IsoTrace History",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description", "transactions"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": ["serializable", "strict-serializable"]
    },
    "transactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/transaction"
      }
    }
  },
  "$defs": {
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ops"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "process": {
          "type": "string"
        },
        "begin": {
          "type": "number"
        },
        "commit": {
          "type": "number"
        },
        "status": {
          "enum": ["committed", "aborted"]
        },
        "ops": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/op"
          }
        }
      }
    },
    "op": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["read", "write", "predicate-read"]
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "$ref": "#/$defs/jsonValue"
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "table": {
          "type": "string",
          "minLength": 1
        },
        "rowId": {
          "$ref": "#/$defs/jsonValue"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        "mutation": {
          "enum": ["insert", "update", "delete"]
        },
        "rowBefore": {
          "oneOf": [
            {
              "$ref": "#/$defs/rowEvidence"
            },
            {
              "type": "null"
            }
          ]
        },
        "rowAfter": {
          "oneOf": [
            {
              "$ref": "#/$defs/rowEvidence"
            },
            {
              "type": "null"
            }
          ]
        },
        "predicate": {
          "type": "object"
        },
        "returnedRows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/predicateReadRow"
          }
        },
        "sourceSql": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "read"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["key", "value", "from"],
            "properties": {
              "predicate": {
                "$ref": "#/$defs/readPredicateEvidence"
              }
            },
            "not": {
              "anyOf": [
                {
                  "required": ["table"]
                },
                {
                  "required": ["rowId"]
                },
                {
                  "required": ["fields"]
                },
                {
                  "required": ["returnedRows"]
                },
                {
                  "required": ["sourceSql"]
                },
                {
                  "required": ["note"]
                },
                {
                  "required": ["mutation"]
                },
                {
                  "required": ["rowBefore"]
                },
                {
                  "required": ["rowAfter"]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "write"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["key", "value"],
            "dependentRequired": {
              "table": ["rowId"],
              "rowId": ["table"],
              "fields": ["table", "rowId"],
              "mutation": ["table", "rowId"],
              "rowBefore": ["table", "rowId"],
              "rowAfter": ["table", "rowId"]
            },
            "allOf": [
              {
                "not": {
                  "anyOf": [
                    {
                      "required": ["from"]
                    },
                    {
                      "required": ["predicate"]
                    },
                    {
                      "required": ["returnedRows"]
                    },
                    {
                      "required": ["sourceSql"]
                    },
                    {
                      "required": ["note"]
                    }
                  ]
                }
              },
              {
                "if": {
                  "properties": {
                    "mutation": {
                      "const": "delete"
                    }
                  },
                  "required": ["mutation"]
                },
                "then": {
                  "required": ["rowBefore"],
                  "not": {
                    "anyOf": [
                      {
                        "required": ["fields"]
                      },
                      {
                        "properties": {
                          "rowAfter": {
                            "$ref": "#/$defs/rowEvidence"
                          }
                        },
                        "required": ["rowAfter"]
                      }
                    ]
                  }
                }
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "predicate-read"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["table", "predicate", "returnedRows"],
            "properties": {
              "predicate": {
                "$ref": "#/$defs/predicateExpression"
              }
            },
            "not": {
              "anyOf": [
                {
                  "required": ["from"]
                },
                {
                  "required": ["key"]
                },
                {
                  "required": ["value"]
                },
                {
                  "required": ["rowId"]
                },
                {
                  "required": ["fields"]
                },
                {
                  "required": ["mutation"]
                },
                {
                  "required": ["rowBefore"]
                },
                {
                  "required": ["rowAfter"]
                }
              ]
            }
          }
        }
      ]
    },
    "predicateExpression": {
      "oneOf": [
        {
          "$ref": "#/$defs/predicateLeaf"
        },
        {
          "$ref": "#/$defs/predicateAll"
        },
        {
          "$ref": "#/$defs/predicateAny"
        },
        {
          "$ref": "#/$defs/predicateNot"
        }
      ]
    },
    "predicateLeaf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["column", "op", "value"],
      "properties": {
        "column": {
          "type": "string",
          "minLength": 1
        },
        "op": {
          "enum": ["=", "!=", "<", "<=", ">", ">="]
        },
        "value": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "predicateAll": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all"],
      "properties": {
        "all": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/predicateExpression"
          }
        }
      }
    },
    "predicateAny": {
      "type": "object",
      "additionalProperties": false,
      "required": ["any"],
      "properties": {
        "any": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/predicateExpression"
          }
        }
      }
    },
    "predicateNot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["not"],
      "properties": {
        "not": {
          "$ref": "#/$defs/predicateExpression"
        }
      }
    },
    "rowEvidence": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "predicateReadRow": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      },
      "properties": {
        "id": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "readPredicateEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["table", "where", "rowId", "sourceSql"],
      "properties": {
        "table": {
          "type": "string",
          "minLength": 1
        },
        "where": {
          "type": "string",
          "minLength": 1
        },
        "rowId": {
          "$ref": "#/$defs/jsonValue"
        },
        "sourceSql": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "jsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}
