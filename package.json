{
  "name": "isotrace",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test && npm run artifacts:check && npm run build && npm run bench",
    "test": "vitest run",
    "demo": "node --import tsx src/cli.ts fixtures/write_skew_doctors.json",
    "demo:strict": "node --import tsx src/cli.ts fixtures/stale_read_strict.json --strict",
    "demo:sql": "node --import tsx src/cli.ts examples/write_skew_sql_trace.sql --sql-trace",
    "analyze": "node --import tsx src/cli.ts",
    "fixtures": "node --import tsx src/cli.ts --fixtures",
    "artifacts:check": "node --import tsx src/artifacts/check.ts",
    "bench": "node --import tsx src/bench/bench.ts",
    "smoke:ui": "node --import tsx src/smoke/ui-smoke.ts",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "playwright": "^1.59.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
